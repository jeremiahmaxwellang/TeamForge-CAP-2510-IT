      filter: brightness(1.1);
    }

    .week-event .ev-title {
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .week-event .ev-time {
      font-size: 9px;
      opacity: .85;
