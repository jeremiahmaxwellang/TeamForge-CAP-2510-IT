    background-color: #273449;
}

.champion-pool-container .table-container table {
    width: 100%;
    min-width: 860px;
    border-collapse: separate;
    border-spacing: 0;
}

.champion-pool-container .table-container thead th {
    padding: 8px 10px;
    font-size: clamp(12px, 0.85vw, 14px);
    font-weight: 700;
    font-family: 'Roboto', sans-serif;
    color: #e2e8f0;
    background-color: #0b1220;
    border-right: 1px solid #334155;
    border-bottom: 1px solid #334155;
    text-align: center;
    white-space: nowrap;
    word-break: keep-all;
}

.champion-pool-container .table-container td {
    padding: 8px 10px;
    border-right: 1px solid #334155;
    border-bottom: 1px solid #334155;
    font-size: clamp(12px, 0.85vw, 14px);
    font-family: 'Roboto', sans-serif;
    color: #e2e8f0;
    background-color: #273449;
    text-align: center;
    white-space: nowrap;
    word-break: keep-all;
}

.champion-pool-container .table-container tr > *:last-child {
    border-right: none;
}

.champion-pool-container .table-container tbody tr:last-child > * {
    border-bottom: none;
}

.champion-pool-container .table-container tbody tr:hover td {
    background-color: #334155;
}

.champion-pool-container .table-container th:nth-child(2),
.champion-pool-container .table-container td:nth-child(2),
.champion-pool-container .table-container th:nth-child(3),
.champion-pool-container .table-container td:nth-child(3),
.champion-pool-container .table-container th:nth-child(6),
.champion-pool-container .table-container td:nth-child(6) {
