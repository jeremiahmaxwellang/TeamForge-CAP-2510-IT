    max-width: 500px;
    background: #3a3d44;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 8px 18px rgba(0,0,0,0.28);
}

.comparison-container .stats-header {
    text-align: center;
    border-bottom: 2px solid rgba(255, 255, 255, 0.12);
