<file path="views/user_settings.html">
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>User Settings</title>
	<link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/topbar-universal.css">
	<style>
		/* Inherit core dashboard styles */
		.coach-page { width: 100%; min-height: 100vh; background-color: var(--porcelain); display: flex; flex-direction: column;}
		.coach-topbar { display: flex; justify-content: space-between; align-items: center; background-color: var(--carbon-black); padding: 10px 20px; color: var(--porcelain); }
		.coach-brand { display: flex; align-items: center; width: 100px; height: 100px; margin-right: 10px; }
		.coach-brand img { width: 100px; height: 100px; margin-right: 10px; margin-left: 20px; }
		.coach-brand-title { font-family: var(--font-road-rage); font-size: 48px; margin-left: 30px; color: var(--porcelain); }
		.coach-team-name { font-size: 36px; color: var(--porcelain); margin-left: auto; margin-right: 20px; }
		.coach-profile-icon { width: 60px; height: 60px; border-radius: 50%; background-color: var(--iron-gray); }
		.coach-content-wrapper { display: flex; width: 100%; }
        .sidebar { width: fit-content; background-color: var(--carbon-black); padding: 10px; height: auto; flex-shrink: 0; min-height: calc(100vh - 120px); }
        .sidebar ul { list-style-type: none; padding: 0; margin: 0; }
        .sidebar ul li a { margin-bottom: 20px; color: var(--porcelain); text-decoration: none; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 150px; text-align: center; }
        .sidebar ul li a img { width: 25%; height: auto; margin-bottom: 5px; transition: filter 0.3s ease; }
        .sidebar ul li a:hover { background-color: #f0f0f0; border-radius: 5px; color: var(--carbon-black); }
        .sidebar ul li a:hover img { filter: invert(1); }
		
        /* Settings Page Specific Styles */
		.settings-main-content { flex-grow: 1; background-color: var(--gunmetal); padding: 30px; display: flex; flex-direction: column; gap: 20px; align-items: center; }
		
        .settings-card {
            background-color: var(--porcelain);
            border-radius: 20px;
            width: 100%;
            max-width: 900px;
            padding: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            color: var(--carbon-black);
        }

        /* Profile Banner */
        .profile-banner { display: flex; align-items: center; gap: 20px; }
        .profile-banner img { width: 100px; height: 100px; border-radius: 50%; background: #ccc; }
        .profile-info h2 { margin: 0 0 5px 0; font-size: 24px; }
        .profile-info p { margin: 0; color: #555; font-size: 16px; }
        .profile-photo-controls { margin-left: auto; display: flex; flex-direction: column; gap: 10px; align-items: flex-end; }
        .profile-photo-controls input[type="file"] { max-width: 220px; }
        .btn-confirm { 
            margin-left: auto; padding: 10px 24px; border-radius: 8px; 
            border: 1px solid #333; background: white; color: #333; 
            font-weight: bold; cursor: pointer; transition: background 0.2s;
        }
        .btn-confirm:hover { background: #f0f0f0; }

        /* Benchmark Settings */
        .settings-card h3 { margin-top: 0; font-size: 22px; margin-bottom: 15px; }
        .role-select { padding: 8px 12px; border-radius: 8px; border: 1px solid #ccc; font-size: 16px; margin-bottom: 20px; outline: none; }
        
        .benchmark-grid {
            display: grid;
            grid-template-columns: 2fr 2fr 1fr;
            gap: 15px 20px;
            align-items: center;
        }
        .benchmark-grid strong { font-size: 18px; border-bottom: 2px solid #ddd; padding-bottom: 5px; }
        
        .metric-row { display: contents; }
        .metric-name { font-size: 16px; color: #333; }
        .comparator-select { padding: 6px; border-radius: 6px; border: 1px solid #ccc; font-size: 14px; }
        .value-input { padding: 6px; border-radius: 6px; border: 1px solid #ccc; font-size: 16px; font-weight: bold; text-align: center; width: 100px; }

        .benchmark-dropdown { border: 1px solid #ddd; border-radius: 12px; padding: 8px 12px; background: #fafafa; }
        .benchmark-dropdown summary { cursor: pointer; font-size: 18px; font-weight: 700; }

        .settings-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 15px; }
        .settings-form-row.single { grid-template-columns: 1fr; }
        .settings-form-row input { padding: 10px; border-radius: 8px; border: 1px solid #ccc; font-size: 15px; }
        .status-text { font-size: 14px; margin-top: 10px; min-height: 18px; }
        .status-text.success { color: #198754; }
        .status-text.error { color: #b42318; }
        .academic-criteria-grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 12px 16px; align-items: center; }
        .academic-criteria-grid strong { font-size: 16px; }
        .academic-criteria-grid label { font-weight: 600; color: #333; }

        /* --- MODAL OVERLAY STYLES --- */
        .modal-overlay {
            position: fixed; 
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            display: none; /* Keeps it hidden until the button is clicked */
            justify-content: center; 
            align-items: center;
            z-index: 1000;
        }
        
        .modal-content {
            background: white; 
            color: #333; 
            padding: 40px; 
            border-radius: 15px;
            width: 95%; 
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            max-height: 85vh; 
            overflow-y: auto;
        }
        
        .btn-cancel { 
            background: #e0e0e0; 
            color: #333; 
            border: none; 
            padding: 10px 20px; 
            border-radius: 8px; 
            font-weight: bold; 
            cursor: pointer; 
        }
        
        .btn-cancel:hover { 
            background: #d0d0d0; 
        }

        .editable-name {
            cursor: pointer;
            border-bottom: 2px dashed transparent;
            transition: border-color 0.2s ease;
            display: inline-block;
        }
        .editable-name:hover {
            border-bottom: 2px dashed #4CAF50; /* Green underline on hover */
        }
	</style>
</head>
<body>
	<div class="coach-page">
		<div class="coach-topbar">
			<div class="coach-brand">
				<img src="/images/teamforge_logo.png" alt="TeamForge Logo">
				<span class="coach-brand-title">TeamForge</span>
			</div>
			<div class="coach-team-name">Viridis Arcus (Team Name)</div>
            <div class="coach-topbar-actions" style="position: relative;">
                <img src="/uploads/profile-photos/defaultusericon.png" alt="Profile Picture" class="coach-profile-icon js-current-user-photo" id="profileDropdownBtn" style="cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s;">
				<div id="profileDropdownMenu" style="display: none; position: absolute; right: 0; top: 75px; background: white; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); width: 160px; overflow: hidden; z-index: 1000; font-family: sans-serif;">
                    <a href="/settings" style="display: block; padding: 12px 16px; color: #333; text-decoration: none; border-bottom: 1px solid #eee; font-weight: 500; transition: background 0.2s;" onmouseover="this.style.backgroundColor='#f5f5f5'" onmouseout="this.style.backgroundColor='transparent'">Settings</a>
                    <a href="/logout" style="display: block; padding: 12px 16px; color: #dc3545; text-decoration: none; font-weight: 500; transition: background 0.2s;" onmouseover="this.style.backgroundColor='#fef0f0'" onmouseout="this.style.backgroundColor='transparent'">Logout</a>
                </div>
			</div>
		</div>

		<div class="coach-content-wrapper">
            <div class="sidebar">
				<ul></ul>
			</div>

			<div class="settings-main-content">
				
                <div class="settings-card profile-banner">
                    <img src="/uploads/profile-photos/defaultusericon.png" alt="Profile" id="settings-profile-photo">
                    <div class="profile-info" style="display: flex; flex-direction: column; gap: 8px;">
                        
                        <div id="name-display-mode">
                            <h2 id="settings-name" class="editable-name" title="Click to edit">Loading Profile...</h2>
                        </div>
                        
                        <div id="name-edit-mode" style="display: none; gap: 10px;">
                            <input type="text" id="input-firstname" placeholder="First Name" style="padding: 8px; border-radius: 6px; border: 1px solid #ccc; font-size: 18px; font-weight: bold; width: 150px;">
                            <input type="text" id="input-lastname" placeholder="Last Name" style="padding: 8px; border-radius: 6px; border: 1px solid #ccc; font-size: 18px; font-weight: bold; width: 150px;">
                        </div>

                        <p id="settings-role" style="margin: 0; color: #555;">Role: ---</p>
                    </div>
                    
                    <div id="edit-action-buttons" style="display: none; margin-left: auto; gap: 10px;">
                        <button class="btn-cancel" id="btn-cancel-edit">Cancel</button>
                        <button class="btn-confirm" id="btn-save-profile">Save Profile</button>
                    </div>

                    <div class="profile-photo-controls">
                        <input type="file" id="profile-photo-input" accept=".png,.jpg,.jpeg,image/png,image/jpeg">
                        <button class="btn-confirm" id="btn-save-photo">Change Profile Photo</button>
                        <p id="photo-status" class="status-text"></p>
                    </div>
                </div>

                <div class="settings-card">
                    <h3>Change Password</h3>
                    <div class="settings-form-row single">
                        <input type="password" id="old-password" placeholder="Old Password">
                    </div>
                    <div class="settings-form-row">
                        <input type="password" id="new-password" placeholder="New Password">
                        <input type="password" id="confirm-new-password" placeholder="Confirm New Password">
                    </div>
                    <div style="text-align: right;">
                        <button class="btn-confirm" id="btn-change-password">Update Password</button>
                    </div>
                    <p id="password-status" class="status-text"></p>
                </div>

                <div class="settings-card" id="team-settings-section" style="display: none;">
                    <h3>Team Settings</h3>
                    <p style="margin-top: 0; color: #555;">Update your team name and logo. Changes are reflected in the top bar across all users.</p>

                    <div class="settings-form-row single">
                        <input type="text" id="team-name-input" maxlength="45" placeholder="Enter team name">
                    </div>

                    <div class="settings-form-row single" style="align-items: center;">
                        <img src="/uploads/team-logos/VA_logo.png" alt="Current Team Logo" id="team-logo-preview" style="width: 90px; height: 90px; object-fit: cover; border-radius: 12px; border: 1px solid #ccc; margin-bottom: 8px;">
                        <input type="file" id="team-logo-input" accept=".png,.jpg,.jpeg,image/png,image/jpeg">
                    </div>

                    <div style="text-align: right;">
                        <button class="btn-confirm" id="btn-save-team-settings">Save Team Settings</button>
                    </div>
                    <p id="team-settings-status" class="status-text"></p>
                </div>

                <div class="settings-card" id="riot-api-key-section" style="display: none;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <h3 style="margin: 0;">Riot API Key</h3>
                        <a href="https://developer.riotgames.com/" target="_blank" rel="noopener noreferrer" class="btn-confirm" style="margin-left: auto; text-decoration: none; display: inline-block;">Get a key</a>
                    </div>
                    <p id="current-riot-api-key" style="margin-top: 0; color: #555;">Most recent Riot API key: Loading...</p>
                    <div class="settings-form-row single">
                        <input type="password" id="riot-api-key-input" placeholder="Enter new Riot API key" autocomplete="off">
                    </div>
                    <div style="text-align: right;">
                        <button class="btn-confirm" id="btn-update-riot-api-key">Confirm</button>
                    </div>
                    <p id="riot-api-key-status" class="status-text"></p>
                </div>

                <div class="settings-card" id="academic-requirements-section" style="display: none;">
                    <h3>Academic Requirements</h3>
                    <p style="margin-top: 0; color: #555;">Set the GPA and CGPA rule that applicants must satisfy during registration. Leave a threshold blank to disable that rule.</p>

                    <div class="academic-criteria-grid">
                        <strong>Metric</strong>
                        <strong>Comparator</strong>
                        <strong>Threshold</strong>

                        <label for="gpa-comparator">GPA</label>
                        <select id="gpa-comparator" class="comparator-select">
                            <option value=">=">≥ (greater than or equal to)</option>
                            <option value="<=">≤ (less than or equal to)</option>
                            <option value=">">&gt; (greater than)</option>
                            <option value="<">&lt; (less than)</option>
                        </select>
                        <input type="number" id="gpa-threshold" class="value-input" min="0" max="5" step="0.01" placeholder="e.g. 2.50">

                        <label for="cgpa-comparator">CGPA</label>
                        <select id="cgpa-comparator" class="comparator-select">
                            <option value=">=">≥ (greater than or equal to)</option>
                            <option value="<=">≤ (less than or equal to)</option>
                            <option value=">">&gt; (greater than)</option>
                            <option value="<">&lt; (less than)</option>
                        </select>
                        <input type="number" id="cgpa-threshold" class="value-input" min="0" max="5" step="0.01" placeholder="e.g. 2.75">
                    </div>

                    <div style="text-align: right; margin-top: 20px;">
                        <button class="btn-confirm" id="btn-save-academic-requirements">Save Academic Requirements</button>
                    </div>
                    <p id="academic-requirements-status" class="status-text"></p>
                </div>

                <div class="settings-card" id="coach-benchmark-section" style="display: none;">
                    <details class="benchmark-dropdown" open>
                        <summary>Benchmark Settings (Team Coach Only)</summary>

                        <div style="padding-top: 12px;">
                            <select id="roleSelect" class="role-select">
                                <option value="1">Role Selected: Top</option>
                                <option value="2">Role Selected: Jungle</option>
                                <option value="3">Role Selected: Mid</option>
                                <option value="4">Role Selected: Bot / ADC</option>
                                <option value="5">Role Selected: Support</option>
                            </select>

                            <div class="benchmark-grid" id="benchmarkGrid">
                                <strong>Metric</strong>
                                <strong></strong> 
                                <strong></strong> 
                                <div style="display:contents;" id="benchmark-rows-container">
                                    <p style="grid-column: span 3;">Loading metrics...</p>
                                </div>
                            </div>

                            <div style="margin-top: 25px; text-align: right;">
                                <button class="btn-confirm" id="saveBenchmarksBtn" style="background: #111; color: white;">Confirm Changes</button>
                            </div>
                        </div>
                    </details>
                </div>

			</div>
		</div>
	</div>
    <script src="/js/current_user_photo.js"></script>
    <script src="/js/team_branding.js"></script>
    <script src="/js/userDropdown.js"></script>
    <script src="/js/sidebar.js"></script>
    <script src="/js/settings.js"></script>
</body>
</html>
