<file path="public/css/evaluation.css">
/* --- START COMPONENT STYLES --- */

  /* The main container for the evaluation card */
  .player-evaluation-card {
    background-color: #fff;
    border-radius: 20px;
    padding: 30px;
    max-width: 600px;
    /* If putting this in a dashboard, remove 'margin: 20px auto' */
    margin: 20px auto; 
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: #333;
  }

  .player-evaluation-card h2 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 25px;
    color: #000;
  }

  /* Grid layout for the 1-5 rating system */
  .rating-grid {
    display: grid;
    grid-template-columns: 140px repeat(5, 1fr); /* 140px is for the text labels */
    gap: 15px;
    align-items: center;
    margin-bottom: 30px;
  }

  .rating-label {
    font-size: 16px;
    font-weight: 500;
    text-align: right;
    padding-right: 15px;
  }

  .rating-header {
    text-align: center;
    font-weight: 600;
    font-size: 18px;
    color: #555;
  }

  /* Custom Radio Buttons Logic */
  .radio-group {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .radio-group input[type="radio"] {
    appearance: none;
    -webkit-appearance: none;
    width: 35px;
    height: 35px;
    background-color: #e0e0e0; /* Unchecked color */
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }

  /* SELECTED STATE (Dark filled circle) */
  .radio-group input[type="radio"]:checked {
    background-color: #333;
    border-color: #333;
    transform: scale(1.1); /* Little pop animation */
  }
  
  /* Hover effects for better UX */
  .radio-group input[type="radio"]:hover {
    background-color: #ccc;
  }
  
  .radio-group input[type="radio"]:checked:hover {
    background-color: #000;
  }

  /* Comment Box Styling */
  .comment-section { margin-bottom: 25px; }
  .comment-section label {
    display: block;
    font-weight: 700;
    font-size: 16px;
    margin-bottom: 10px;
  }

  .comment-box {
    width: 100%;
    height: 120px;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
