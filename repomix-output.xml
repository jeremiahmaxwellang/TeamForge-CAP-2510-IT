<file path="public/css/player_analysis/summary.css">
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background: transparent;
  font-family: 'Inter', sans-serif;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.panel {
  background: #f0f2f5;
  border-radius: 10px;
  padding: 24px 20px 20px;
  width: 100%;
  max-width: 1060px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
}

/* Title */
.panel-title {
  font-size: 36px;
  font-weight: 700;
  color: white;
  margin-bottom: 16px;
  letter-spacing: -0.01em;
}

/* Recommendation */
.recommendation {
  background: #ffffff;
  border: 1px solid #474747;
  border-radius: 6px;
  padding: 14px 16px;
  margin-bottom: 16px;
}

.rec-title {
  background: #0B1220;
  font-size: 24px;
  font-weight: 700;
  color: white;
  padding: 8px 10px;
  border-radius: 4px;
  margin-bottom: 5px;
}

.rec-text {
  font-size: 16px;
  color: var(--carbon-black);
}

/* Grid */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

@media (max-width: 680px) {
  .grid {
    grid-template-columns: 1fr;
  }
}

/* Section card */
.section {
  background: #ffffff;
  border: 1px solid #474747;
  border-radius: 6px;
  overflow: hidden;
  align-self: start;
}

.section-header {
  padding: 10px 14px;
  border-bottom: 1px solid #474747;
}

.section-title {
  font-size: 21px;
  font-weight: 700;
  color: #1a1a1a;
}

.section-sub {
  font-size: 16px;
  font-weight: 400;
  color: #555;
}

/* Tables */
table {
  width: 100%;
  border-collapse: collapse;
}

th {
  font-size: 12px;
  font-weight: 600;
  color: #666;
  text-align: left;
  padding: 8px 14px;
  background: #f7f8fa;
  border-bottom: 1px solid #dde1e7;
}

td {
  font-size: 14px;
  color: #333;
  padding: 10px 14px;
  border-bottom: 1px solid #eef0f3;
  vertical-align: middle;
}

tr:last-child td {
  border-bottom: none;
}

/* Match Scrims overlay table colors for the Summary overview table */
#overview-table {
  border-collapse: separate;
  border-spacing: 0;
  color: #e2e8f0;
}

#overview-table thead th {
  background: #0b1220;
  color: #e2e8f0;
  border-right: 1px solid #334155;
  border-bottom: 1px solid #334155;
  font-size: 16px;
}

#overview-table tbody tr {
  background: #273449;
}

#overview-table td {
  color: #e2e8f0;
  border-right: 1px solid #334155;
  border-bottom: 1px solid #334155;
  font-size: 16px;
}

#overview-table tr > *:last-child {
  border-right: none;
}

/* Center-align Games (col 2) and Average CSM (col 5) */
#overview-table thead th:nth-child(2),
#overview-table thead th:nth-child(5),
#overview-table tbody td:nth-child(2),
#overview-table tbody td:nth-child(5) {
  text-align: center;
}

/* champ-table, scrims-table, and scrim highlights table — same color & font styles as overview-table */
#champ-table,
#scrims-table,
.scrim_highlights_table {
  border-collapse: separate;
  border-spacing: 0;
  color: #e2e8f0;
}

#champ-table thead th,
#scrims-table thead th,
.scrim_highlights_table thead th {
  background: #0b1220;
  color: #e2e8f0;
  border-right: 1px solid #334155;
  border-bottom: 1px solid #334155;
  font-size: 16px;
}

#champ-table tbody tr,
#scrims-table tbody tr,
.scrim_highlights_table tbody tr {
  background: #273449;
}

#champ-table td,
#scrims-table td,
.scrim_highlights_table td {
  color: #e2e8f0;
  border-right: 1px solid #334155;
  border-bottom: 1px solid #334155;
  font-size: 16px;
}

#champ-table tr > *:last-child,
#scrims-table tr > *:last-child,
.scrim_highlights_table tr > *:last-child {
  border-right: none;
}

#champ-table tbody tr:last-child td,
#scrims-table tbody tr:last-child td,
.scrim_highlights_table tbody tr:last-child td {
  border-bottom: none;
}

/* Keep the 'Games' header in one line for scrim highlights */
.scrim_highlights_table thead th:last-child {
  white-space: nowrap;
}

/* Center specific Scrim Highlights columns */
.scrim_highlights_table thead th:nth-child(2),
.scrim_highlights_table thead th:nth-child(3),
.scrim_highlights_table thead th:nth-child(5),
.scrim_highlights_table tbody td:nth-child(2),
.scrim_highlights_table tbody td:nth-child(3),
.scrim_highlights_table tbody td:nth-child(5) {
  text-align: center;
}

/* Center-align Scrims columns: Avg Game Sense, Avg Comms, Avg Champ */
#scrims-table thead th:nth-child(1),
#scrims-table thead th:nth-child(2),
#scrims-table thead th:nth-child(3),
#scrims-table tbody td:nth-child(1),
#scrims-table tbody td:nth-child(2),
#scrims-table tbody td:nth-child(3) {
  text-align: center;
}

/* Center-align Games Played (col 2) */
#champ-table thead th:nth-child(2),
#champ-table tbody td:nth-child(2) {
  text-align: center;
}

/* Role cell */
.role-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.lane-role-icon {
  width: 28px;
  height: 28px;
  object-fit: contain;
  flex-shrink: 0;
}

.role-name {
  font-size: 14px;
  color: #555;
  text-align: center;
}

.games-num {
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
}

/* Donut */
.donut-cell {
  display: flex;
  align-items: center;
  gap: 8px;
}

.donut {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}

.wr-text {
  font-size: 14px;
  font-weight: 700;
  color: #1a1a1a;
}

/* KDA */
.kda-text {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
}

#overview-table .role-name,
#overview-table .games-num,
#overview-table .wr-text,
#overview-table .kda-text {
  color: #e2e8f0;
}

/* Red score */
.score-red {
  color: #d93025;
  font-weight: 600;
}

/* Scrim highlights */
.highlights {
  padding: 12px 14px;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.hl-row {
  font-size: 13px;
  color: #333;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4px 8px;
  padding: 10px 0;
  border-bottom: 1px solid #eef0f3;
}

.hl-row:last-child {
  border-bottom: none;
}

.hl-key {
  font-weight: 700;
  color: #1a1a1a;
  white-space: nowrap;
}

.hl-val {
  color: #333;
}
