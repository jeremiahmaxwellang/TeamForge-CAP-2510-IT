<file path="public/css/player_analysis/scrims.css">
.overlay {
  --scrims-bg: #2f3136;
  --scrims-times-played-bg: #ffffff0a;
  --scrims-border: #334155;
  --scrims-text: #e2e8f0;
  --scrims-text-muted: #cbd5e1;
  --scrims-accent: #38bdf8;
  --scrims-accent-strong: #0ea5e9;
  --scrims-win: #14532d;
  --scrims-loss: #7f1d1d;
  --scrims-selected: #075985;
  --scrims-porcelain: #eef2f3;
}

.overlay {
  box-sizing: border-box;
  width: auto;
  max-width: calc(100% - 10px);
  margin: 20px;
  background: var(--scrims-bg);
  padding: 20px;
  border-radius: 10px;
  overflow: visible;
  word-break: break-word;
  border: 1px solid var(--scrims-border);
  box-shadow: 0 18px 36px rgba(2, 6, 23, 0.45);
  font-family: 'Roboto', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  color: var(--scrims-text);
}

@media (max-width: 680px) {
  .overlay {
    margin: 10px;
    max-width: calc(100% - 20px);
    padding: 12px;
  }
}

.overlay-container {
  max-width: 100%;
  overflow: visible;
}

.overlay-content {
  display: flex;
  gap: 14px;
  align-items: flex-start;
}

.scrim-list, .times-played-list, .evaluation-form {
  flex: 1;
}

.times-played-list {
  flex: 0 0 auto;
  width: fit-content;
  max-width: 100%;
}

.scrim-list {
  flex: 1.35;
}

.playerEvaluationHeader {
  flex: 1;
  min-width: 0;
}

.scrim-list,
.times-played-list,
.player-evaluation-card {
  align-self: flex-start;
}

.times-played-table-frame {
  width: 235px;
  background-color: #1e293b;
  border: 1px solid var(--scrims-border);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 10px 24px rgba(2, 6, 23, 0.35);
}

.scrim-table-frame {
  width: 100%;
  background-color: #1e293b;
  border: 1px solid var(--scrims-border);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 24px rgba(2, 6, 23, 0.35);
}

.times-played-list h2 {
  margin: 0;
  padding-top: 5px;
  padding-bottom: 10px;
  font-size: 20px;
  display: inline-block;
}

.scrim-list h2 {
  margin: 0;
  padding-top: 5px;
  padding-bottom: 10px;
  font-size: 20px;
}

.scrim-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.scrim-filter-wrapper {
  display: flex;
  align-items: center;
  gap: 8px;
  padding-top: 5px;
  padding-bottom: 10px;
}

.scrim-filter-label {
  color: var(--scrims-text-muted);
  font-size: 13px;
  font-weight: 600;
}

.scrim-filter-select {
  background-color: #0f172a;
  color: var(--scrims-text);
  border: 1px solid var(--scrims-border);
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 13px;
  font-weight: 600;
  min-width: 140px;
}

.scrim-filter-select:focus {
  outline: 1px solid var(--scrims-accent);
  border-color: var(--scrims-accent);
}

.scrim-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  border-radius: 0;
  overflow: visible;
}

.scrim-table,
.times-played-table {
  background-color: var(--scrims-times-played-bg);
  color: var(--scrims-text);
  box-shadow: none;
}

.scrim-table th, .scrim-table td {
  border-right: 1px solid var(--scrims-border);
  border-bottom: 1px solid var(--scrims-border);
  padding: 8px 10px;
  font-size: clamp(12px, 0.85vw, 14px);
  word-break: keep-all;
}

.scrim-table tr > *:last-child {
  border-right: none;
}

.scrim-table tbody tr:last-child > * {
  border-bottom: none;
}

.scrim-table tbody tr {
  background-color: #273449;
}

.scrim-table thead th {
  font-weight: 700;
}

.scrim-win {
  background-color: #273449;
}

.scrim-loss {
  background-color: #273449;
}

.scrim-selected {
  background-color: #334155;
  outline: 1px solid var(--scrims-porcelain);
  outline-offset: -1px;
}

.scrim-selected th,
.scrim-selected td {
  border-color: var(--scrims-porcelain);
}

.scrim-empty-row td {
  text-align: left;
  color: var(--scrims-text-muted);
}

.times-played-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  border-radius: 0;
  overflow: visible;
  background-color: var(--scrims-times-played-bg);
  box-shadow: none;
}

.times-played-table th, .times-played-table td {
  border-right: 1px solid var(--scrims-border);
  border-bottom: 1px solid var(--scrims-border);
  padding: 4px;
  font-size: clamp(12px, 0.85vw, 14px);
}

.times-played-table td {
  padding-left: 12px;
}

.times-played-table th:nth-child(2),
.times-played-table td:nth-child(2),
.times-played-table th:nth-child(3),
.times-played-table td:nth-child(3) {
  text-align: center;
}

.times-played-table tr > *:last-child {
  border-right: none;
}

.times-played-table tbody tr:last-child > * {
  border-bottom: none;
}

.times-played-row {
  background-color: #273449;
}

.times-played-row th {
  word-break: keep-all;
}

.rating-group {
  margin-bottom: 15px;
}

.comment-group {
  margin-bottom: 15px;
}

.confirm-btn {
  background-color: #28b5ff;
  color: white;
  padding: 10px 20px;
  border: none;
  cursor: pointer;
}

 /* --- START EVALUATION STYLES --- */

  /* The main container for the evaluation card */
  .overlay-container h1 {
    margin-top: 0;
    margin-bottom: 0;
    padding-top: 10px;
    padding-bottom: 10px;
    color: var(--scrims-text); /* Header color from Figma variables */
    font-size: clamp(36px, 2.4vw, 48px);
    letter-spacing: 0.3px;
  }

  .playerEvaluationHeader h2 {
    margin-top: 0;
    margin-bottom: 0;
    padding-top: 10px;
    padding-bottom: 10px;
    color: var(--scrims-text);
    font-size: 20px;
  }

  .player-evaluation-card {
    background-color: #1e293b;
    border: 1px solid var(--scrims-border);
    border-radius: 20px;
    padding: 20px;
    max-width: 460px;
    /* If putting this in a dashboard, remove 'margin: 20px auto' */
    margin: 0; 
    box-shadow: 0 10px 24px rgba(2, 6, 23, 0.35);
    font-family: 'Roboto', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: var(--scrims-text);
  }

  .player-evaluation-card h3 {
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 10px;
    color: #f8fafc;
    font-size: clamp(18px, 1.2vw, 24px);
  }

  #evalForm {
    background-color: var(--scrims-times-played-bg);
  }

  /* Grid layout for the 1-5 rating system */
  .rating-grid {
    display: grid;
    grid-template-columns: 120px repeat(5, 1fr); /* 120px is for the text labels */
    gap: 12px;
    align-items: center;
    margin-bottom: 22px;
  }

  .rating-label {
    font-size: clamp(13px, 0.9vw, 15px);
    font-weight: 600;
    text-align: right;
    padding-right: 15px;
    color: var(--scrims-text-muted);
  }

  .rating-header {
    text-align: center;
    font-weight: 600;
    font-size: clamp(15px, 1vw, 18px);
    color: var(--scrims-text-muted);
  }

  /* Custom Radio Buttons Logic */
  .radio-group {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .radio-group input[type="radio"] {
    appearance: none;
    -webkit-appearance: none;
    width: 28px;
    height: 28px;
    background-color: #475569; /* Unchecked color */
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid #64748b;
  }

  /* SELECTED STATE (Dark filled circle) */
  .radio-group input[type="radio"]:checked {
    background-color: var(--scrims-accent);
    border-color: var(--scrims-accent);
    transform: scale(1.1); /* Little pop animation */
  }
  
  /* Hover effects for better UX */
  .radio-group input[type="radio"]:hover {
    background-color: #64748b;
  }
  
  .radio-group input[type="radio"]:checked:hover {
    background-color: var(--scrims-accent-strong);
  }

  /* Comment Box Styling */
  .comment-section { margin-bottom: 25px; }
  .comment-section label {
    display: block;
    font-weight: 700;
    font-size: clamp(15px, 1vw, 18px);
    margin-bottom: 10px;
    color: var(--scrims-text);
  }

  .comment-box {
    width: 100%;
    height: 105px;
    border: 2px solid var(--scrims-border);
    border-radius: 12px;
    padding: 15px;
    font-family: inherit;
    font-size: clamp(12px, 0.85vw, 14px);
    resize: none;
    line-height: 1.5;
    color: var(--scrims-text);
    background-color: #0f172a;
    box-sizing: border-box; 
  }
  
  .comment-box:focus {
    outline: none;
    border-color: var(--scrims-accent);
    background-color: #111827;
  }

  /* Confirm Button Styling */
  .confirm-btn-container { text-align: right; }
  
  .confirm-btn {
    background-color: transparent;
    border: 2px solid var(--scrims-accent);
    color: var(--scrims-accent);
    padding: 10px 30px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .confirm-btn:hover {
    background-color: var(--scrims-accent);
    color: #082f49;
  }

  .scrim-table thead tr,
  .times-played-table thead tr {
    background-color: #0b1220;
  }

  .scrim-table a {
    color: var(--scrims-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .scrim-table a:hover {
    color: #7dd3fc;
    text-decoration: underline;
  }

  .dropdown-btn {
    background-color: #0f172a;
    color: var(--scrims-text);
    border: 1px solid var(--scrims-border);
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 500;
  }

  .dropdown-content {
    background-color: #0f172a;
    border: 1px solid var(--scrims-border);
    box-shadow: 0 10px 24px rgba(2, 6, 23, 0.45);
  }

  .dropdown-content a {
    color: var(--scrims-text);
  }

  .dropdown-content a:hover {
    background-color: #1e293b;
  }

  /* --- END COMPONENT STYLES --- */

  /* ── LAYOUT ───────────────────────────────────────────── */
.overlay-content {
  display: flex;
  gap: 20px;
  align-items: flex-start;
}

.times-played-list {
  flex: 0 0 235px;
}

.scrim-list {
  flex: 1;
  min-width: 0;
}

/* Remove the old right-panel evaluation styles */
.playerEvaluationHeader { display: none; }
.player-evaluation-card { display: none; }

/* ── SCRIM TABLE — extra columns ──────────────────────── */
.scrim-table th:nth-child(4),  /* Team column — wider */
.scrim-table td:nth-child(4) {
  min-width: 200px;
}

.scrim-table th:last-child,
.scrim-table td:last-child {
  text-align: center;
  border-right: none;
}

/* V button */
.eval-toggle-btn {
  background-color: #1e293b;
  color: var(--scrims-text);
  border: 1px solid var(--scrims-border);
  border-radius: 6px;
  width: 32px;
  height: 32px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.eval-toggle-btn:hover,
.eval-toggle-btn.active {
  background-color: var(--scrims-selected);
  border-color: var(--scrims-accent);
  color: var(--scrims-accent);
}

/* ── INLINE EVALUATION ROW ────────────────────────────── */
.eval-inline-row td {
  background-color: #172032;
  padding: 16px 20px;
  border-bottom: 1px solid var(--scrims-border);
}

.eval-inline-row.hidden { display: none; }

.eval-inline-content {
  display: flex;
  gap: 32px;
  align-items: flex-start;
}

/* Left side: rating grid */
.eval-inline-left { flex: 1; }

.eval-player-title {
  font-size: 16px;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 12px;
}

.eval-range-hint {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.eval-range-hint span {
  background: #1e3a5f;
  color: var(--scrims-accent);
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 4px;
}

.inline-rating-grid {
  display: grid;
  grid-template-columns: 100px repeat(5, 36px);
  gap: 8px;
  align-items: center;
  margin-bottom: 0;
}

.inline-rating-grid .rating-label {
  font-size: 13px;
  font-weight: 600;
  text-align: left;
  padding-right: 0;
  color: var(--scrims-text-muted);
}

.inline-rating-grid .rating-header {
  text-align: center;
  font-size: 13px;
  font-weight: 600;
  color: var(--scrims-text-muted);
}

/* number labels above columns */
.inline-col-labels {
  display: grid;
  grid-template-columns: 100px repeat(5, 36px);
  gap: 8px;
  margin-bottom: 4px;
}

.inline-col-label {
  text-align: center;
  font-size: 12px;
  color: var(--scrims-text-muted);
  font-weight: 600;
}

/* Right side: comment + confirm */
.eval-inline-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.eval-inline-right label {
  font-weight: 700;
  font-size: 14px;
  color: var(--scrims-text);
}

.eval-inline-comment {
  width: 100%;
  height: 90px;
  border: 2px solid var(--scrims-border);
  border-radius: 10px;
  padding: 10px 14px;
  font-family: inherit;
  font-size: 13px;
  resize: none;
  color: var(--scrims-text);
  background-color: #0f172a;
  box-sizing: border-box;
}

.eval-inline-comment:focus {
  outline: none;
  border-color: var(--scrims-accent);
}

.eval-inline-confirm {
  align-self: flex-end;
  background-color: transparent;
  border: 2px solid var(--scrims-accent);
  color: var(--scrims-accent);
  padding: 8px 28px;
  font-size: 15px;
  font-weight: 600;
  border-radius: 30px;
  cursor: pointer;
  transition: all 0.2s;
}

.eval-inline-confirm:hover {
  background-color: var(--scrims-accent);
  color: #082f49;
}
</file>

<file path="public/css/style.css">
@import url('vars.css');
@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap');

/* Start of player_analysis styles */
/* Global styles */
html, body {
    height: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden; /* Prevents horizontal overflow */
}

body {
    font-family: Arial, sans-serif;
    display: flex;
    background-color: var(--porcelain); /* Background color from Figma variables */
}

.container {
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Sidebar styles */
.sidebar {
    width: fit-content;
    background-color: var(--carbon-black); /* Sidebar background color from Figma variables */
    padding: 10px;
    height: auto;
    flex-shrink: 0; /* Prevents sidebar from shrinking */
}

.sidebar ul {
    list-style-type: none; /* Removes default list bullets */
    padding: 0;
    margin: 0; /* Removes default margin */
}

.sidebar ul li {
    text-align: center; /* Ensures the text is centered if there's text next to the image */
}

.sidebar ul li a {
    margin-bottom: 20px;
    color: var(--porcelain); /* Default text color */
    text-decoration: none; /* Removes underline from links */
    display: flex; /* Make <a> a flex container */
    flex-direction: column; /* Stack the image and text vertically */
    align-items: center; /* Center the content inside the link */
    justify-content: center; /* Ensure items are centered inside the <a> */
    width: 150px;
}

.sidebar ul li a img {
    width: 25%; /* Adjust image size */
    height: auto; /* Maintain aspect ratio */
    margin-bottom: 5px; /* Space between image and text */
    transition: filter 0.3s ease; /* Smooth transition for the image */
