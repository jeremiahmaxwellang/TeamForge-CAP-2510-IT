    .modal-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .modal {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 24px;
      width: 380px;
      max-width: 95vw;
      transform: translateY(10px);
      transition: transform .2s;
      box-shadow: 0 20px 60px rgba(0, 0, 0, .5);
    }

