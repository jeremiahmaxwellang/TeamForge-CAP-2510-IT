<file path="public/css/announcements.css">
html,
body {
    height: 100%;
}

body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: var(--porcelain);
    display: flex;
    flex-direction: column;
}

.container {
    display: flex;
    flex-direction: column;
}

.header_container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--carbon-black);
    padding: 10px 20px;
    color: var(--porcelain);
}

.logo {
    display: flex;
    align-items: center;
    width: 100px;
    height: 100px;
    margin-right: 10px;
    text-decoration: none;
    color: var(--porcelain);
}

.logo img {
    width: 100px;
    height: 100px;
    margin-right: 10px;
    margin-left: 20px;
}

.header_title {
    font-family: var(--font-road-rage);
    font-size: 48px;
    margin-left: 30px;
    color: var(--porcelain);
}

.team-name {
    font-size: 36px;
    color: var(--porcelain);
    margin-left: auto;
    margin-right: 20px;
}

.topbar-actions {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-right: 20px;
}

.logout-btn {
    display: inline-block;
    padding: 10px 14px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--porcelain);
    background: #2b2d31;
    border: 1px solid #5b6069;
    font-weight: 600;
}

.logout-btn:hover {
    background: #3b3f46;
}

.content-wrapper {
    display: flex;
    width: 100%;
    flex: 1;
}

/* --- SIDEBAR (Inherited from Settings coach-sidebar) --- */
.sidebar {
    width: fit-content;
    background-color: var(--carbon-black);
    padding: 10px;
    height: auto;
    flex-shrink: 0;
    min-height: calc(100vh - 120px);
}

.sidebar ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
}

.sidebar ul li a {
    margin-bottom: 20px;
    color: var(--porcelain);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 150px;
    text-align: center;
}

.sidebar ul li a img {
    width: 25%;
    height: auto;
    margin-bottom: 5px;
    transition: filter 0.3s ease;
}

.sidebar ul li a:hover {
    background-color: #f0f0f0;
    border-radius: 5px;
    color: var(--carbon-black);
}

.sidebar ul li a:hover img {
    filter: invert(1);
}

/* --- MAIN CONTENT (Inherited from settings-main-content) --- */
.main-content {
    flex-grow: 1;
    background-color: var(--gunmetal);
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
}

/* --- CARD (Inherited from settings-card) --- */
.announcement-card {
    background-color: var(--porcelain);
    border-radius: 20px;
    width: 100%;
    max-width: 900px;
    padding: 30px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    color: var(--carbon-black);
    display: flex;
    flex-direction: column;
    margin-top: 30px;
}

/* --- ANNOUNCEMENT SPECIFICS --- */
.announcement-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.announcement-header h2 {
    font-size: 28px;
    margin: 0;
}

.btn-add-new {
    background-color: #111;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 15px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
}

.btn-add-new:hover {
    background-color: #333;
}

.announcement-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-height: 60vh;
    /* Prevents card from stretching forever */
    overflow-y: auto;
    padding-right: 15px;
}

.announcement-list::-webkit-scrollbar {
    width: 8px;
}

.announcement-list::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
}

.announcement-list::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 10px;
}

.announcement-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    border-bottom: 1px solid #ddd;
    padding-bottom: 15px;
}

.announcement-item:last-child {
    border-bottom: none;
}

.announcement-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0;
    color: #111;
    cursor: pointer;
    transition: color 0.2s;
}

.announcement-title:hover {
    color: #00f2c3;
}

.announcement-body {
    font-size: 15px;
    color: #555;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* --- MODAL STYLES (Inherited from Settings) --- */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    color: #333;
    padding: 40px;
    border-radius: 15px;
    width: 95%;
    max-width: 800px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    max-height: 85vh;
    overflow-y: auto;
}

.modal-content input,
.modal-content textarea {
    width: 100%;
    padding: 12px;
    margin-bottom: 20px;
    margin-top: 8px;
    border: 1px solid #ccc;
    border-radius: 8px;
    box-sizing: border-box;
    font-family: inherit;
    font-size: 15px;
}

.modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 15px;
}

.btn-cancel {
    background: #e0e0e0;
    color: #333;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
}

.btn-submit {
    background: #111;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
}
</file>

<file path="public/css/attendance.css">
:root {
    --gunmetal: #2f3136;
    --carbon-black: #202225;
    --iron-gray: #36393f;
    --porcelain: #f2f3f5;
    --font-road-rage: 'Road Rage', sans-serif;
}

body {
    margin: 0;
    display: block;
    min-height: 100vh;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: var(--gunmetal);
    color: #ffffff;
}

/* ── Attendance Header ── */
.attendance-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
}

.attendance-header h2 {
    font-size: 36px;
    margin: 0;
    font-weight: 700;
    letter-spacing: 0.4px;
}

.attendance-divider {
    border: none;
    border-top: 1px solid #45474d;
    margin: 12px 0 20px;
}

/* ── Selects ── */
.attendance-select {
    background-color: #202225;
    color: var(--porcelain);
    border: 1px solid #45474d;
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 14px;
    font-family: inherit;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg xmlns='[w3.org](http://www.w3.org/2000/svg)' width='12' height='12' viewBox='0 0 12 12'%3E%3Cpath fill='%23b9bbbe' d='M6 8L1 3h10z'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 32px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
}

.attendance-select:hover,
.attendance-select:focus {
    border-color: #7289da;
    background-color: #2b2d31;
    outline: none;
}

.event-select {
    min-width: 340px;
}

.event-selector-row {
    margin-bottom: 20px;
}

/* ── Table ── */
.attendance-table-wrapper {
    overflow-x: auto;
    border-radius: 12px;
}

.attendance-table {
    width: 100%;
    min-width: 780px;
    border-collapse: collapse;
    border-radius: 12px;
    overflow: hidden;
}

.attendance-table th {
    background-color: #202225;
    color: var(--porcelain);
    padding: 12px 16px;
    text-align: left;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    border-bottom: 1px solid #45474d;
}

.attendance-table td {
    padding: 14px 16px;
    border-bottom: 1px solid #3f4248;
    color: #f2f3f5;
    vertical-align: middle;
}

.attendance-table tr:nth-child(even) {
    background-color: #2b2d31;
}

.attendance-table tr:hover {
    background-color: #3b3f46;
}

/* ── Participant Cell ── */
.participant-cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.participant-name {
    font-weight: 600;
    font-size: 14px;
    color: var(--porcelain);
}

.participant-meta {
    font-size: 12px;
    color: #b9bbbe;
}

/* ── Radio Buttons styled as colored checkboxes ── */
.att-radio {
    appearance: none;
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 5px;
    border: 2px solid currentColor;
    cursor: pointer;
    position: relative;
    transition: background-color 0.15s ease;
    display: inline-block;
    vertical-align: middle;
}

.att-radio.present  { color: #3ba55c; }
.att-radio.late     { color: #faa81a; }
.att-radio.absent   { color: #ed4245; }
.att-radio.excused  { color: #5865f2; }

.att-radio:checked {
    background-color: currentColor;
}

.att-radio:checked::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 6px;
    width: 5px;
    height: 9px;
    border: 2px solid #fff;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
}

.att-radio:hover:not(:checked) {
    background-color: color-mix(in srgb, currentColor 20%, transparent);
}

/* ── Note Input ── */
.note-input {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid #45474d;
    color: #b9bbbe;
    font-family: inherit;
    font-size: 13px;
    font-style: italic;
    padding: 4px 2px;
    width: 140px;
    transition: border-color 0.2s ease, color 0.2s ease;
}

.note-input:focus {
    outline: none;
    border-bottom-color: #7289da;
    color: var(--porcelain);
}

.note-input::placeholder {
    color: #5b6069;
}

/* ── RSVP Icons ── */
.rsvp-icon {
    font-size: 20px;
    display: inline-block;
}

.rsvp-yes { filter: hue-rotate(100deg) saturate(1.5); }  /* green tint */
.rsvp-no  { filter: hue-rotate(320deg) saturate(2);   }  /* red tint   */

/* ── Footer / Save ── */
.attendance-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 24px;
}

.save-btn {
    background-color: #3ba55c;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background-color 0.2s ease;
}

.save-btn:hover {
    background-color: #2d8a4e;
}

/* ── Responsive ── */
@media (max-width: 900px) {
    .attendance-header {
        flex-direction: column;
        align-items: flex-start;
    }

    .event-select {
        min-width: 100%;
    }

    .note-input {
        width: 100px;
    }
}
</file>

