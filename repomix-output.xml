    .hday {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .hday-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .hday-name {
      font-size: 12px;
      font-weight: 600;
      min-width: 70px;
    }

    .hday-bar-wrap {
      flex: 1;
      background: var(--card);
      border-radius: 20px;
      height: 20px;
      overflow: hidden;
      position: relative;
