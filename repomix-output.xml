<file path="public/css/coach_dashboard.css">
.coach-page {
	width: 100%;
	min-height: 100vh;
	background-color: var(--porcelain);
	display: flex;
	flex-direction: column;
}

.coach-topbar {
	width: 100%;
	box-sizing: border-box;
	display: flex;
	justify-content: space-between;
	align-items: center;
	background-color: var(--carbon-black);
	padding: 5px 20px;
	color: var(--porcelain);
}

.coach-brand {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-right: 10px;
}

.coach-brand img {
	width: 80px;
	height: 80px;
	margin-right: 10px;
	margin-left: 20px;
}

.coach-brand-title {
	font-family: var(--font-road-rage);
	font-size: 36px;
	margin-left: 30px;
	color: var(--porcelain);
}

.coach-team-name {
	font-size: 24px;
	color: var(--porcelain);
	margin-left: auto;
	margin-right: 20px;
}

.coach-topbar-actions {
	display: flex;
	align-items: center;
	gap: 12px;
}

.logout-btn {
	display: inline-block;
	padding: 8px 12px;
	border-radius: 10px;
	text-decoration: none;
	color: var(--porcelain);
	background: #2b2d31;
	border: 1px solid #5b6069;
	font-weight: 600;
}

.logout-btn:hover {
	background: #3b3f46;
}

.coach-profile-icon {
	width: 60px;
	height: 60px;
	border-radius: 50%;
	background-color: var(--iron-gray);
}

.coach-content-wrapper {
	display: flex;
	width: 100%;
}

.coach-sidebar {
	width: fit-content;
	background-color: var(--carbon-black);
	padding: 10px;
	height: auto;
	flex-shrink: 0;
}

.coach-sidebar ul {
	list-style-type: none;
	padding: 0;
	margin: 0;
}

.coach-sidebar ul li {
	text-align: center;
}

.coach-sidebar ul li a {
	margin-bottom: 20px;
	color: var(--porcelain);
	text-decoration: none;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	width: 150px;
}

.coach-sidebar ul li a img {
	width: 25%;
	height: auto;
	margin-bottom: 5px;
	transition: filter 0.3s ease;
}

.coach-sidebar ul li a:hover {
	background-color: #f0f0f0;
	border-radius: 5px;
	color: var(--carbon-black);
}

.coach-sidebar ul li a:hover img {
	filter: invert(1);
}

.coach-main-content {
	flex-grow: 1;
	min-width: 0;
	padding-right: 20px;
	box-sizing: border-box;
	background-color: var(--gunmetal);
	min-height: calc(100vh - 120px);
}

.dashboard-shell {
	margin: 0;
	padding: 20px;
	min-height: calc(100vh - 160px);
	color: var(--porcelain);
	display: grid;
	grid-template-columns: repeat(3, minmax(0, 1fr));
	grid-template-rows: auto auto auto;
	gap: 20px;
	/* Grid Areas Map:
	Row 1: Player List (Spans 2 cols), Announcements (1 col)
	Row 2: Tourney Draft (1 col), Calendar (1 col), Team Stats (1 col)
	Row 3: Scrims (Spans 2 cols), (Empty space under calendar)
	*/
	grid-template-areas:
		"players players announcements"
		"draft calendar stats"
		"scrims scrims .";
}

.dashboard-shell h2 {
	margin: 0;
	font-size: 28px;
}

.dashboard-shell p {
	margin-top: 10px;
	font-size: 16px;
}

/* Base Card Styling */
.dash-card {
	background-color: #2f3136;
	color: #fff;
	border-radius: 20px;
	padding: 20px;
	box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
	display: flex;
	flex-direction: column;
	margin-bottom: auto;
}

.dash-card h3 {
	margin-top: 0;
	margin-bottom: 15px;
	font-size: 24px;
	color: #fff;
	border-bottom: 2px solid #333;
	padding-bottom: 10px;
}

.dash-card p,
.dash-card th,
.dash-card td,
.dash-card label,
.dash-card small,
.dash-card strong,
.dash-card h4 {
	color: #fff;
}

/* Assigning Grid Areas */
#card-players { grid-area: players; }
#card-announcements { grid-area: announcements; }
#card-stats {
	grid-area: stats;
	overflow: hidden;
}
#card-draft { grid-area: draft; }
#card-calendar { grid-area: calendar; align-self: start; }
#card-scrims { grid-area: scrims; }

#team-stats-carousel {
	width: 100%;
	min-width: 0;
	overflow: hidden;
}

/* --- DASHBOARD ANNOUNCEMENTS --- */
.dash-announcement-list {
	display: flex;
	flex-direction: column;
	gap: 15px;
	max-height: 280px;
	overflow-y: auto;
	padding-right: 10px;
}

.dash-announcement-list::-webkit-scrollbar { width: 6px; }
.dash-announcement-list::-webkit-scrollbar-track { background: #111; border-radius: 10px; }
.dash-announcement-list::-webkit-scrollbar-thumb { background: #444; border-radius: 10px; }

.dash-announcement-item {
	cursor: pointer;
	padding: 10px;
	border-radius: 8px;
	transition: background-color 0.2s;
}

.dash-announcement-item:hover {
	background-color: #181818;
}

.dash-announcement-item h4 {
	margin: 0 0 5px 0;
	font-size: 16px;
	color: #fff;
}

.dash-announcement-item p {
	margin: 0;
	font-size: 13px;
	color: #fff;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
	text-overflow: ellipsis;
	word-wrap: break-word;
}

/* --- DASHBOARD MODAL --- */
.modal-overlay {
	position: fixed;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background: rgba(0, 0, 0, 0.6);
	display: none;
	justify-content: center;
	align-items: center;
	z-index: 1000;
}

.modal-content {
	background: white;
	color: #333;
	padding: 40px;
	border-radius: 15px;
	width: 95%;
	max-width: 800px;
	box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
	max-height: 85vh;
	overflow-y: auto;
}

.btn-cancel {
	background: #e0e0e0;
	color: #333;
	border: none;
	padding: 10px 20px;
	border-radius: 8px;
	font-weight: bold;
	cursor: pointer;
}

/* --- TEAM STATS CAROUSEL --- */
.carousel-container {
	position: relative;
	width: 100%;
	flex-grow: 1;
	overflow: hidden;
	display: grid;
	grid-template-columns: 40px minmax(0, 1fr) 40px;
	column-gap: 6px;
	align-items: center;
}

.carousel-window {
	width: 100%;
	min-width: 0;
	overflow: hidden;
}

.carousel-track {
	display: flex;
	transition: transform 0.5s ease-in-out;
	width: 100%;
}

.carousel-slide {
	min-width: 100%;
	max-width: 100%;
	box-sizing: border-box;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 25px;
}

/* Left and Right Arrows */
.carousel-btn {
	background: none;
	border: none;
	font-size: 28px;
	cursor: pointer;
	color: #fff;
	position: static;
	transform: none;
	z-index: 10;
	transition: color 0.2s, transform 0.2s;
	width: 40px;
	height: 40px;
	display: flex;
	align-items: center;
	justify-content: center;
}

.carousel-btn:hover {
	color: #00f2c3;
	transform: scale(1.1);
}

.carousel-btn.prev { justify-self: start; }
.carousel-btn.next { justify-self: end; }

/* Carousel Winrate-style Donut */
.carousel-winrate {
	display: flex;
	flex-direction: column;
	justify-content: center;
	gap: 6px;
	position: relative;
	padding: 10px 0 10px 96px;
}

.carousel-winrate::before {
	content: "";
	position: absolute;
	left: 14px;
	top: 50%;
	transform: translateY(-50%);
	width: 64px;
	height: 64px;
	border-radius: 50%;
	background: conic-gradient(
		var(--ring-fill, #28b5ff) var(--winrate-angle, 0deg),
		var(--ring-empty, #444) 0deg
	);
	box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
}

.carousel-winrate::after {
	content: "";
	position: absolute;
	left: 30px;
	top: 50%;
	transform: translateY(-50%);
	width: 32px;
	height: 32px;
	border-radius: 50%;
	background: #2f3136;
	box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.03);
}

.carousel-winrate-pct {
	font-size: 28px;
	font-weight: 600;
	color: #fff;
}

.carousel-winrate-sub {
	font-size: 16px;
	color: #fff;
}



/* --- SCROLLABLE TABLES --- */
.scrollable-table-container {
	max-height: 355px;
	overflow-y: auto;
	padding-right: 5px;
}

.scrollable-table-container th {
	position: sticky;
	top: 0;
	background-color: #2f3136;
	color: #fff;
	z-index: 2;
	box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.1);
}

.scrollable-table-container::-webkit-scrollbar { width: 6px; }
.scrollable-table-container::-webkit-scrollbar-track { background: #111; border-radius: 10px; }
.scrollable-table-container::-webkit-scrollbar-thumb { background: #444; border-radius: 10px; }

/* --- LATEST SCRIMS TABLE --- */
.scrim-badge {
	padding: 4px 8px;
	border-radius: 6px;
	font-weight: bold;
	font-size: 12px;
	text-align: center;
	display: inline-block;
	width: 30px;
}

.badge-w {
	background-color: #d4edda;
	color: #000;
	border: 1px solid #c3e6cb;
}

.badge-l {
	background-color: #f8d7da;
	color: #000;
	border: 1px solid #f5c6cb;
}

.vod-link {
	color: #aed6f1;
	text-decoration: underline;
	font-weight: bold;
}

.vod-link:hover {
	text-decoration: underline;
	color: #aed6f1;
}

/* --- CALENDAR WIDGET --- */
.calendar-controls {
	display: flex;
	justify-content: center;
	gap: 10px;
	margin-bottom: 15px;
}

.calendar-controls select {
	padding: 6px 12px;
	border-radius: 8px;
	border: 1px solid #444;
	font-size: 16px;
	color: #fff;
	background-color: #111;
	cursor: pointer;
	outline: none;
}

.calendar-grid {
	display: grid;
	grid-template-columns: repeat(7, 1fr);
	gap: 5px;
	text-align: center;
}

.calendar-cell {
	padding: 8px 0;
	border-radius: 6px;
	font-size: 14px;
	font-weight: 500;
}

.calendar-header-cell {
	font-weight: bold;
	padding-bottom: 10px;
}

.calendar-day:hover {
	background-color: #181818;
	cursor: pointer;
}

/* Figma Color Matching */
.color-sunday { color: #fff; }
.color-weekday { color: #fff; }

.calendar-today {
	background-color: #00f2c3;
	color: white !important;
	font-weight: bold;
}
</file>

<file path="public/css/comparison.css">
/* Player Comparison Styles */

.overlay {
