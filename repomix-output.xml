<file path="public/css/applicant_list.css">
/* Role and Rank Logo Styles for Applicant List */
.role-logo, .rank-logo {
    height: 24px;
    width: 24px;
    object-fit: contain;
    vertical-align: middle;
    margin-right: 6px;
}
.role-label, .rank-label {
    vertical-align: middle;
}
body {
    margin: 0;
    display: block;
    min-height: 100vh;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: var(--gunmetal);
    color: #ffffff;
}

.coach-page {
    width: 100%;
    height: auto;
    min-height: 100vh;
    background-color: var(--gunmetal);
    display: flex;
    flex-direction: column;
    margin-bottom: 0px;
}

.coach-topbar {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--carbon-black);
    padding: 10px 20px;
    color: var(--porcelain);
}

.coach-brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100px;
    height: 100px;
    margin-right: 10px;
}

.coach-brand img {
    width: 100px;
    height: 100px;
    margin-right: 10px;
    margin-left: 20px;
}

.coach-brand-title {
    font-family: var(--font-road-rage);
    font-size: 48px;
    margin-left: 30px;
    color: var(--porcelain);
}

.coach-team-name {
    font-size: 36px;
    color: var(--porcelain);
    margin-left: auto;
    margin-right: 20px;
}

.coach-topbar-actions {
    display: flex;
    align-items: center;
    gap: 12px;
}

.logout-btn {
    display: inline-block;
    padding: 10px 14px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--porcelain);
    background: #2b2d31;
    border: 1px solid #5b6069;
    font-weight: 600;
}

.logout-btn:hover {
    background: #3b3f46;
}

.coach-profile-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: var(--iron-gray);
}

.coach-content-wrapper {
    display: flex;
    width: 100%;
    flex: 1;
    min-width: 0;
}

.coach-sidebar {
    width: fit-content;
    height: auto;
    min-height: 100%;
    background-color: var(--carbon-black);
    padding: 10px;
    flex-shrink: 0;
}

.coach-sidebar ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
}

.coach-sidebar ul li {
    text-align: center;
}

.coach-sidebar ul li a {
    margin-bottom: 20px;
    color: var(--porcelain);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 150px;
}

.coach-sidebar ul li a img {
    width: 25%;
    height: auto;
    margin-bottom: 5px;
    transition: filter 0.3s ease;
}

.coach-sidebar ul li a:hover {
    background-color: #f0f0f0;
    border-radius: 5px;
    color: var(--carbon-black);
}

.coach-sidebar ul li a:hover img {
    filter: invert(1);
}

.coach-main-content {
    min-width: 0;
    flex-grow: 1;
    padding: 20px;
}

.container {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    background: var(--gunmetal);
    box-sizing: border-box;
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid #202225;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.28);
}

.coach-main-content .container {
    padding: 30px;
    background-color: #2f3136;
}

.applicant-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 30px;
}

.back-btn {
    display: inline-block;
    background-color: #202225;
    color: #f2f3f5;
    text-decoration: none;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid #45474d;
    font-weight: 600;
    transition: background-color 0.2s ease, border-color 0.2s ease;
}

.back-btn:hover {
    background-color: #3b3f46;
    border-color: #5b5f67;
}

h1 {
    color: #ffffff;
    margin: 0;
    text-align: left;
    font-weight: 700;
    letter-spacing: 0.4px;
}

.header-title-section h2 {
    font-size: 36px;
}

table {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    margin-top: 20px;
    overflow: hidden;
    border-radius: 12px;
}

@media (max-width: 1200px) {
    .coach-main-content {
        padding: 20px;
    }
}

th {
    background-color: #202225;
    color: var(--porcelain);
    padding: 12px;
    text-align: left;
    font-weight: 600;
    border-bottom: 1px solid #45474d;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
}

td {
    padding: 12px;
    border-bottom: 1px solid #3f4248;
    text-align: left;
    color: #f2f3f5;
}

tr:nth-child(even) {
    background-color: #2b2d31;
}

tr:hover {
    background-color: #3b3f46;
}

.loading {
    text-align: center;
    padding: 30px;
    color: #b9bbbe;
    background: #202225;
    border-radius: 12px;
}

.error {
    color: #ffd4d9;
    text-align: center;
    padding: 20px;
    background-color: rgba(220, 53, 69, 0.2);
    border: 1px solid #dc3545;
    border-radius: 12px;
}

.status {
    padding: 6px 12px;
    border-radius: 999px;
    font-weight: 700;
    text-align: center;
    font-size: 12px;
    display: inline-block;
}

.status.pending {
    background-color: rgba(255, 193, 7, 0.2);
    color: #ffd66b;
}

.status.active {
    background-color: rgba(0, 242, 195, 0.18);
    color: #00f2c3;
}

.status.inactive {
    background-color: rgba(220, 53, 69, 0.2);
    color: #ff7b8a;
}

.status.evaluated {
    background-color: rgba(52, 152, 219, 0.2);
    color: #8dc8ff;
}

.status.accepted {
    background-color: rgba(40, 167, 69, 0.24);
    color: #7ce79c;
}

.status.rejected {
    background-color: rgba(220, 53, 69, 0.24);
    color: #ff9aa6;
}

.clickable-row {
    cursor: pointer;
    transition: background-color 0.15s ease;
}

@media (max-width: 900px) {
    .container {
        padding: 18px;
        border-radius: 12px;
    }

    .applicant-header {
        flex-direction: column;
        align-items: flex-start;
    }

    table {
        font-size: 13px;
    }

    th,
    td {
        padding: 10px 8px;
    }
}
</file>

<file path="public/css/applicant_profile.css">
/* --- GLOBAL LAYOUT --- */
body {
    margin: 0;
    padding: 0;
    background-color: var(--gunmetal);
    color: white;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow-x: hidden;
}

.content-wrapper {
    display: flex;
    flex: 1;
    width: 100%;
}

/* --- MAIN CONTENT --- */
.main-content {
    flex-grow: 1;
    padding: 40px;
    width: calc(100% - 110px);
    box-sizing: border-box;
}

.header-title-section {
    margin-bottom: 25px;
    color: white;
}

.header-title-section h2 {
    font-size: 36px;
    margin: 0px;
}

/* --- 3-BOX GRID LAYOUT --- */
.profile-top-section {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 25px;
    margin-bottom: 40px;
    align-items: stretch;
}

.right-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.white-card {
    background: #2f3136;
    color: #dcddde;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    height: 100%;
    box-sizing: border-box;
}

/* --- Left Box Elements --- */
.applicant-select {
    color: #ffffff;
    font-size: 24px;
    font-weight: bold;
    border: none;
    background: transparent;
    cursor: pointer;
    width: 100%;
    outline: none;
    margin-bottom: 5px;
    /* Hide default browser arrow */
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
}

.applicant-select option {
    background-color: #2f3136;
    color: #dcddde;
    font-size: 16px;
}

.real-name {
    color: var(--porcelain);
    margin-bottom: 20px;
    font-size: 16px;
}

/* --- Role Toggle Buttons --- */
.role-toggle-container {
    display: flex;
    gap: 15px;
    margin-bottom: 25px;
}

.role-btn {
    background: #3a3d44;
    border: 2px solid #4f545c;
    color: #b9bbbe;
    padding: 8px 15px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.2s;
    flex-grow: 1;
    text-align: left;
}

.role-btn strong {
    color: #dcddde;
    font-size: 15px;
}

.role-btn:hover:not(:disabled) {
    background: #42454d;
}

/* Active State (Green) */
.role-btn.active {
    background: rgba(0, 242, 195, 0.1);
    border-color: #00f2c3;
}

.role-btn.active strong {
    color: #00f2c3;
}

.contact-section h4,
.student-section h4 {
    font-size: 14px;
    font-weight: bold;
    margin-bottom: 12px;
    text-transform: uppercase;
    color: var(--porcelain);
    border-bottom: 1px solid #4f545c;
    padding-bottom: 5px;
}

.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    font-size: 14px;
}

/* --- Rank Box --- */
/* --- Timer Info Status Styles --- */
#timerInfo {
    padding: 6px 0;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    display: inline-block;
    transition: background 0.2s, color 0.2s;
}

#timerInfo.ready {
    color: #007bff;
}

#timerInfo.fetching {
    color: #fbbf24;
}

#timerInfo.success {
    color: #22c55e;
}

#timerInfo.error {
    color: #ef4444;
}
.rank-box-content {
    display: flex;
    align-items: center;
    justify-content: space-around;
    height: 100%;
}

.rank-group {
    display: flex;
    align-items: center;
    gap: 10px;
}

.rank-img {
    width: 50px;
    height: 50px;
    object-fit: contain;
}

.rank-text h5 {
    margin: 0;
    font-size: 12px;
    color: #8e9297;
}

.rank-text span {
    font-weight: bold;
    font-size: 18px;
    color: var(--porcelain);
}

.vertical-divider {
    width: 1px;
    height: 50px;
    background-color: #4f545c;
}

/* --- Student Box --- */
.student-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    font-size: 14px;
}

.info-label {
    font-size: 12px;
    color: #8e9297;
    display: block;
}

.info-value {
    font-weight: bold;
    font-size: 15px;
    color: var(--porcelain);
}

/* --- Stats Bar --- */
.stats-bar-container {
    margin-bottom: 30px;
}

.stats-bar {
    background-color: #4a4a4a;
    padding: 0 20px;
    height: 100px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.stat-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-grow: 1;
}

.stat-group {
    text-align: center;
}

.stat-big {
    font-size: 28px;
    font-weight: bold;
}

.stat-divider {
    width: 1px;
    height: 50px;
    background: #777;
}

.nav-arrow {
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    width: 40px;
    height: 60px;
    border-radius: 8px;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.nav-arrow:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
}

/* --- Radio Buttons --- */
.rating-grid {
    display: grid;
    grid-template-columns: 3fr repeat(5, 1fr);
    gap: 10px;
    align-items: center;
    margin-bottom: 20px;
}

.rating-header {
    font-weight: bold;
    color: #8e9297;
    font-size: 14px;
    text-align: center;
}

.rating-label {
    font-weight: 600;
    font-size: 15px;
}

.radio-group {
    text-align: center;
}

.custom-radio {
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: #4f545c;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
}

.custom-radio:hover {
    background-color: #5d6269;
}

.custom-radio:checked {
    background-color: #00f2c3;
    transform: scale(1.3);
    box-shadow: 0 0 8px rgba(0, 242, 195, 0.6);
}

/* --- Comparison & Bottom Section --- */
.profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
    margin-top: 30px;
    margin-bottom: 30px;
}

.card-header {
    text-align: center;
    font-weight: bold;
    font-size: 24px;
    margin-bottom: 20px;
    display: block;
    color: var(--porcelain);
    border-bottom: 1px solid #4f545c;
    padding-bottom: 10px;
}

.comparison-container {
    text-align: center;
}

.summary-box {
    background: #36393f;
    border: 1px solid #4f545c;
    padding: 15px;
    border-radius: 8px;
    font-size: 13px;
    text-align: left;
    margin-top: 15px;
    color: var(--porcelain);
}

.interview-wrapper {
    background: #2f3136;
    color: var(--porcelain);
    border-radius: 15px;
    padding: 30px;
    margin-bottom: 100px;
}

.interview-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
}

.question-block {
    margin-bottom: 20px;
}

.question-block label {
    display: block;
    font-weight: bold;
    margin-bottom: 8px;
    color: #dcddde;
}

.question-block textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #4f545c;
    border-radius: 8px;
    background: #36393f;
    color: var(--porcelain);
    resize: vertical;
    min-height: 80px;
    font-family: inherit;
}

.question-block textarea::placeholder {
    color: #8e9297;
}

.eval-comment {
    width: 100%;
    margin-top: 5px;
    padding: 10px;
    border: 1px solid #4f545c;
    border-radius: 5px;
    resize: vertical;
    background: #36393f;
    color: var(--porcelain);
    font-family: inherit;
    box-sizing: border-box;
}

.eval-comment::placeholder {
    color: #8e9297;
}

.vod-box {
    background: black;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
