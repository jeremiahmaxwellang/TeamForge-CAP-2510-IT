    display: flex;
    flex-direction: column;
    align-items: center;
}

.comparison-header {
    text-align: center;
    font-size: 24px;
    font-weight: bold;
    color: #f1f3f5;
    margin-bottom: 10px;
}

.player-selection {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-bottom: 20px;
}

.player-selector {
    display: flex;
    flex-direction: column;
