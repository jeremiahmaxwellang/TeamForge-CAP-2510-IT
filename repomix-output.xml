<file path="src/modules/calendar/calendar.html">
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TeamForge – Calendar</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #1a1d24;
      --sidebar: #13151b;
      --panel: #22262f;
      --card: #2a2f3a;
      --border: #2f3540;
      --text: #e8ecf0;
      --muted: #8892a0;
      --green: #22c55e;
      --green-dk: #16a34a;
      --blue: #38bdf8;
      --blue-dk: #0284c7;
      --red: #ef4444;
      --orange: #f97316;
      --yellow: #facc15;
      --event-scrim: #f97316;
      --event-class: #ef4444;
      --event-tournament: #facc15;
      --event-team: #38bdf8;
      --event-other: #a78bfa;
      --sidebar-w: 200px;
      --header-h: 56px;
    }

    body {
      font-family: 'Barlow', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
      overflow: hidden;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--sidebar);
      display: flex;
      flex-direction: column;
      padding: 16px 0;
      gap: 0;
      border-right: 1px solid var(--border);
      overflow-y: auto;
      flex-shrink: 0;
    }

    .sidebar-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 26px;
      font-weight: 700;
      color: #fff;
      padding: 0 16px 20px;
      letter-spacing: .5px;
    }

    .create-btn {
      margin: 0 12px 20px;
      background: var(--green);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 10px 0;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: background .2s;
      width: calc(100% - 24px);
    }

    .create-btn:hover {
      background: var(--green-dk);
    }

    .sidebar-section {
      padding: 0 12px;
      margin-bottom: 16px;
    }

    .sidebar-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 8px;
      padding: 0 4px;
    }

    .date-row {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 8px;
    }

    .date-input-group {
      flex: 1;
    }

    .date-input-group label {
      font-size: 10px;
      color: var(--muted);
      display: block;
      margin-bottom: 3px;
    }

    .date-input-group input {
      width: 100%;
      background: var(--card);
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 6px;
      padding: 5px 8px;
      font-size: 11px;
      font-family: inherit;
    }

    .get-schedule-btn {
      width: 100%;
      background: var(--green);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 9px 0;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      margin-bottom: 16px;
      transition: background .2s;
    }

    .get-schedule-btn:hover {
      background: var(--green-dk);
    }

    .calendar-list {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .cal-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 8px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
      transition: background .2s;
    }

    .cal-item:hover {
      background: rgba(255, 255, 255, .06);
    }

    .cal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      flex-shrink: 0;
      border: 2px solid transparent;
    }

    .cal-dot.checked {
      border-color: transparent;
    }

    .tournament-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .tournament-search {
      width: 100%;
      background: var(--card);
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 6px;
      padding: 6px 10px;
      font-size: 12px;
      font-family: inherit;
      margin-bottom: 6px;
    }

    .tournament-item {
      padding: 5px 4px;
      font-size: 12px;
      color: var(--muted);
      cursor: pointer;
      border-radius: 4px;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color .15s;
    }

    .tournament-item:hover {
      color: var(--text);
    }

    .tournament-item .t-color {
      width: 8px;
      height: 8px;
      border-radius: 2px;
      flex-shrink: 0;
    }

    .sidebar-arrow {
      font-size: 11px;
      color: var(--muted);
      cursor: pointer;
      padding: 4px 16px;
      margin-bottom: 4px;
    }

    /* ── MAIN ── */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      overflow: hidden;
    }

    /* ── TOP BAR ── */
    .topbar {
      height: var(--header-h);
      display: flex;
      align-items: center;
      padding: 0 20px;
      gap: 16px;
      border-bottom: 1px solid var(--border);
      background: var(--panel);
      flex-shrink: 0;
    }

    .nav-btn {
      background: none;
      border: none;
      color: var(--muted);
      font-size: 18px;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 4px;
      line-height: 1;
      transition: color .15s;
    }

    .nav-btn:hover {
      color: var(--text);
    }

    .month-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      min-width: 160px;
    }

    .events-count {
      font-size: 12px;
      color: var(--muted);
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .events-count svg {
      width: 14px;
      height: 14px;
      fill: var(--blue);
    }

    .view-toggle {
      display: flex;
      background: var(--card);
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .view-btn {
      background: none;
      border: none;
      color: var(--muted);
      padding: 6px 16px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: all .15s;
    }

    .view-btn.active {
      background: var(--green);
      color: #fff;
    }

    .view-btn:not(.active):hover {
      color: var(--text);
    }

    /* ── CALENDAR AREA ── */
    .calendar-area {
      flex: 1;
      overflow: hidden;
      display: flex;
    }

    /* ── MONTH VIEW ── */
    .month-view {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .month-header {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      background: var(--panel);
      border-bottom: 1px solid var(--border);
    }

    .month-dow {
      text-align: center;
      padding: 10px 0;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: var(--muted);
    }

    .month-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      grid-auto-rows: 1fr;
      flex: 1;
      overflow: hidden;
    }

    .month-cell {
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 6px 8px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      gap: 3px;
      min-height: 90px;
      transition: background .15s;
      position: relative;
      overflow: hidden;
    }

    .month-cell:nth-child(7n) {
      border-right: none;
    }

    .month-cell:hover {
      background: rgba(255, 255, 255, .04);
    }

    .month-cell.other-month .day-num {
      color: #3a3f4a;
    }

    .month-cell.today .day-num {
      background: var(--green);
      color: #fff;
      border-radius: 50%;
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .day-num {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      line-height: 1;
      margin-bottom: 2px;
    }

    .month-event {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 6px;
      border-radius: 3px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      cursor: pointer;
      color: #fff;
    }

    .more-events {
      font-size: 10px;
      color: var(--muted);
      padding: 1px 4px;
    }

    /* ── WEEK VIEW ── */
    .week-view {
      flex: 1;
      display: flex;
      overflow: hidden;
    }

    .week-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .week-header-row {
      display: grid;
      grid-template-columns: 56px repeat(7, 1fr);
      border-bottom: 1px solid var(--border);
      background: var(--panel);
      flex-shrink: 0;
    }

    .week-tz {
      padding: 10px 0;
      text-align: center;
      font-size: 10px;
      color: var(--muted);
    }

    .week-dow-cell {
      text-align: center;
      padding: 8px 4px;
      border-left: 1px solid var(--border);
    }

    .week-dow-cell .dow-name {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .6px;
      color: var(--muted);
    }

    .week-dow-cell .dow-date {
      font-size: 16px;
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
    }

    .week-dow-cell.today .dow-date {
      color: var(--green);
    }

    .week-body {
      flex: 1;
      overflow-y: auto;
      display: grid;
      grid-template-columns: 56px repeat(7, 1fr);
      position: relative;
    }

    .week-body::-webkit-scrollbar {
      width: 4px;
    }

    .week-body::-webkit-scrollbar-track {
      background: transparent;
    }

    .week-body::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 2px;
    }

    .time-col {
      display: flex;
      flex-direction: column;
    }

    .time-slot-label {
      height: 48px;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 4px;
      font-size: 10px;
      color: var(--muted);
      flex-shrink: 0;
    }

    .day-col {
      border-left: 1px solid var(--border);
      position: relative;
      cursor: pointer;
    }

    .day-col:hover {
      background: rgba(255, 255, 255, .02);
    }

    .hour-line {
      height: 48px;
      border-bottom: 1px solid rgba(255, 255, 255, .04);
      flex-shrink: 0;
    }

    .week-event {
      position: absolute;
      left: 3px;
      right: 3px;
      border-radius: 5px;
      padding: 3px 6px;
      font-size: 10px;
      font-weight: 600;
      color: #fff;
      overflow: hidden;
      cursor: pointer;
      z-index: 2;
      transition: filter .15s;
    }

