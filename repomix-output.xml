    .hday-bar {
      height: 100%;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 8px;
      font-size: 10px;
      font-weight: 700;
      color: #fff;
      transition: width .6s ease;
    }

    .hday-pct {
      font-size: 11px;
      color: var(--muted);
      min-width: 52px;
      text-align: right;
    }

    .hday-dots {
      display: flex;
      gap: 3px;
      flex-wrap: wrap;
      padding-left: 78px;
    }

    .hdot {
      width: 10px;
      height: 10px;
      border-radius: 2px;
    }

    .free-slots {
      padding: 0 16px 16px;
    }

    .free-slots-title {
      font-size: 11px;
      font-weight: 700;
      color: #fff;
      background: rgba(34, 197, 94, .15);
