}

.champion-pool-container .champion-pool-icon {
    width: 30px;
    height: 30px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid #334155;
    background-color: #1e293b;
}

.champion-pool-container .champion-name {
    font-weight: 600;
    color: #e2e8f0;
}

.champion-pool-container .role-cell {
    display: flex;
